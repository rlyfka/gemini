local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local function getExecutorName()
	local name = (identifyexecutor and identifyexecutor())
		or (getexecutorname and getexecutorname())
		or ""
	return name:lower()
end

local function isBlacklisted()
	local exec = getExecutorName()

	local blacklist = {"xeno", "solara"}
	for _, v in ipairs(blacklist) do
		if exec:find(v) then
			return true
		end
	end

	if xenolib or xeno then
		return true
	end

	if solara or is_solara_executor then
		return true
	end

	return false
end

if isBlacklisted() then
	LocalPlayer:Kick("Executor is not supported\nDsc.gg/getjxs")
end
